# OpenCite API keys (loaded by opencite.Config.from_env())
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=
OPENALEX_API_KEY=

# OpenCite contact email (required for polite API access)
OPENCITE_EMAIL=your@email.com

# CrossRef polite pool email (used by get-bibtex)
CROSSREF_EMAIL=your@email.com

# Optional: Mistral API key for PDF conversion
MISTRAL_API_KEY=

# CiteBot log level (DEBUG, INFO, WARNING, ERROR)
CITEBOT_LOG_LEVEL=WARNING
